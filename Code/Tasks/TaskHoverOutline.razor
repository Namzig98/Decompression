@using System.Linq;
@using Sandbox;
@using Sandbox.UI;
@namespace Decompression
@inherits PanelComponent

<root>
	@if ( showOutline )
	{
		<div class="hover-prompt">
			<div class="prompt-text">[E] @hoveredName</div>
		</div>
	}
</root>

@code {
	private bool showOutline;
	private string hoveredName = "";

	private RealTimeSince timeSinceLastDiagLog = 9999f;

	protected override void OnUpdate()
	{
		showOutline = false;

		var match = Decompression.Match.Current;
		if ( match is null || match.State != MatchState.Round ) return;

		var camera = Game.ActiveScene?
			.GetAllComponents<CameraComponent>()
			.FirstOrDefault( c => c.IsMainCamera );
		if ( camera is null ) return;

		const float reach = 150f;
		var origin = camera.WorldPosition;
		var direction = camera.WorldRotation.Forward;
		var trace = Game.ActiveScene.Trace
			.Ray( origin, origin + direction * reach )
			.Run();

		// Diagnostic: log every ~0.5s what the trace is hitting + whether
		// we found a TaskObject + whether it's assigned to local.
		if ( timeSinceLastDiagLog > 0.5f )
		{
			timeSinceLastDiagLog = 0f;
			var hitName = trace.GameObject?.Name ?? "(none)";
			var task = trace.GameObject?.Components.Get<Decompression.TaskObject>( includeDisabled: true )
				?? trace.GameObject?.Root?.Components.Get<Decompression.TaskObject>( includeDisabled: true );
			Log.Info( $"HoverOutline: hit={trace.Hit} obj={hitName} task={(task is null ? "null" : task.DisplayName)} mine={(task?.IsAssignedToLocal ?? false)} done={(task?.IsCompleted ?? false)}" );
		}

		if ( !trace.Hit || trace.GameObject is null ) return;

		var taskComp = trace.GameObject.Components.Get<Decompression.TaskObject>( includeDisabled: true )
			?? trace.GameObject.Root?.Components.Get<Decompression.TaskObject>( includeDisabled: true );

		if ( taskComp is null ) return;
		if ( !taskComp.IsAssignedToLocal ) return;
		if ( taskComp.IsCompleted ) return;

		showOutline = true;
		hoveredName = $"{taskComp.LocationLabel} — {taskComp.DisplayName}";
	}

	protected override int BuildHash() => System.HashCode.Combine( showOutline, hoveredName );
}
