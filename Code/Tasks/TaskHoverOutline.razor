@using System.Linq;
@using Sandbox;
@using Sandbox.UI;
@namespace Decompression
@inherits PanelComponent

<root>
	@if ( showOutline )
	{
		<div class="hover-prompt">
			<div class="prompt-text">[E] @hoveredName</div>
		</div>
	}
</root>

@code {
	private bool showOutline;
	private string hoveredName = "";

	// Track the task the local player is currently hovering so we can
	// clear its IsLocallyHovered flag when they look away.
	private Decompression.TaskObject lastHovered;

	protected override void OnUpdate()
	{
		Decompression.TaskObject newHovered = null;
		showOutline = false;

		var match = Decompression.Match.Current;
		if ( match is null || match.State != MatchState.Round )
		{
			UpdateHoveredFlag( null );
			return;
		}

		var camera = Game.ActiveScene?
			.GetAllComponents<CameraComponent>()
			.FirstOrDefault( c => c.IsMainCamera );
		if ( camera is null )
		{
			UpdateHoveredFlag( null );
			return;
		}

		const float reach = 150f;
		var origin = camera.WorldPosition;
		var direction = camera.WorldRotation.Forward;

		// Exclude the local player from the trace — otherwise the camera-
		// forward ray hits the player's own collider before reaching the task.
		var localPlayer = Game.ActiveScene
			.GetAllComponents<Decompression.Player>()
			.FirstOrDefault( p => p.Network.Owner == Connection.Local );

		var traceBuilder = Game.ActiveScene.Trace
			.Ray( origin, origin + direction * reach );

		if ( localPlayer is not null )
		{
			traceBuilder = traceBuilder.IgnoreGameObjectHierarchy( localPlayer.GameObject );
		}

		var trace = traceBuilder.Run();

		if ( trace.Hit && trace.GameObject is not null )
		{
			var taskComp = trace.GameObject.Components.Get<Decompression.TaskObject>( includeDisabled: true )
				?? trace.GameObject.Root?.Components.Get<Decompression.TaskObject>( includeDisabled: true );

			if ( taskComp is not null && taskComp.IsAssignedToLocal && !taskComp.IsCompleted )
			{
				newHovered = taskComp;
				showOutline = true;
				hoveredName = $"{taskComp.LocationLabel} — {taskComp.DisplayName}";
			}
		}

		UpdateHoveredFlag( newHovered );
	}

	private void UpdateHoveredFlag( Decompression.TaskObject newHovered )
	{
		if ( newHovered == lastHovered ) return;

		if ( lastHovered is not null && lastHovered.IsValid() )
			lastHovered.IsLocallyHovered = false;
		if ( newHovered is not null )
			newHovered.IsLocallyHovered = true;

		lastHovered = newHovered;
	}

	protected override void OnDestroy()
	{
		// Clear our hover flag if we're destroyed mid-hover.
		if ( lastHovered is not null && lastHovered.IsValid() )
			lastHovered.IsLocallyHovered = false;
	}

	protected override int BuildHash() => System.HashCode.Combine( showOutline, hoveredName );
}
